TELEGRAM_BOT_LINK=https://t.me/testvpnservice1_bot

TELEGRAM_CHANEL_NAME=@your_channel
TELEGRAM_CHANEL_LINK=t.me/your_channel_link

PAYMENT_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me/test

HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_MAIL_TO_ADDRESS=
SANCTUM_STATEFUL_DOMAINS=your-domain.com

TELEGRAM_NOTIFY_PASSIVE_ENABLED=false
